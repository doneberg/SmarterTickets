@page "/tickets/{Id:int}"
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Nav
@rendermode InteractiveServer
@using SmarterTickets.Core.DTOs
@using SmarterTickets.Core.Enums
@using SmarterTickets.Services

<PageTitle>Ticket #@Id</PageTitle>

@if (_ticket == null)
{
    <p>Loading...</p>
}
else
{
    <div class="container">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3>@_ticket.Title</h3>
                <a href="/tickets" class="btn btn-secondary">Back to Tickets</a>
            </div>
            <div class="card-body">
                <p>@_ticket.Description</p>
                <div class="row mb-3">
                    <div class="col-md-3">
                        <strong>Status:</strong>
                        <span class="badge @GetStatusBadge(_ticket.Status)">@_ticket.Status</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Priority:</strong>
                        <span class="badge @GetPriorityBadge(_ticket.Priority)">@_ticket.Priority</span>
                    </div>
                    <div class="col-md-3">
                        <strong>Created By:</strong> @_ticket.CreatedByName
                    </div>
                    <div class="col-md-3">
                        <strong>Created At:</strong> @_ticket.CreatedAt.ToLocalTime().ToString("MM/dd/yyyy")
                    </div>
                </div>

                @if (Session.IsAdmin)
                {
                    <hr />
                    <h5>Admin Controls</h5>
                    <div class="row g-3 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label">Change Status</label>
                            <select class="form-select" @bind="_selectedStatus">
                                @foreach (var status in Enum.GetValues<TicketStatus>())
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Change Priority</label>
                            <select class="form-select" @bind="_selectedPriority">
                                @foreach (var priority in Enum.GetValues<TicketPriority>())
                                {
                                    <option value="@priority">@priority</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-warning w-100" @onclick="UpdateTicket">
                                Update Ticket
                            </button>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-danger w-100" @onclick="DeleteTicket">
                                Delete Ticket
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <h4>Comments</h4>
        @if (_comments == null)
        {
            <p>Loading comments...</p>
        }
        else if (!_comments.Any())
        {
            <p>No comments yet.</p>
        }
        else
        {
            @foreach (var comment in _comments)
            {
                <div class="card mb-2">
                    <div class="card-body d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1">@comment.Content</p>
                            <small class="text-muted">
                                @comment.CreatedByName — @comment.CreatedAt.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt")
                            </small>
                        </div>
                        @if (Session.IsAdmin)
                        {
                            <button class="btn btn-sm btn-outline-danger" 
                                    @onclick="() => DeleteComment(comment.Id)">
                                Delete
                            </button>
                        }
                    </div>
                </div>
            }
        }

        <div class="card mt-4">
            <div class="card-header">Add Comment</div>
            <div class="card-body">
                <div class="mb-3">
                    <textarea class="form-control" @bind="_newComment" rows="3" 
                              placeholder="Write a comment..."></textarea>
                </div>
                <button class="btn btn-primary" @onclick="AddComment">
                    Submit Comment
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private TicketDto? _ticket;
    private List<CommentDto>? _comments;
    private string _newComment = string.Empty;
    private TicketStatus _selectedStatus;
    private TicketPriority _selectedPriority;

    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await LoadTicket();
        await LoadComments();
    }

    private async Task LoadTicket()
    {
        _ticket = await Http.GetFromJsonAsync<TicketDto>($"tickets/{Id}");
        if (_ticket != null)
        {
            _selectedStatus = _ticket.Status;
            _selectedPriority = _ticket.Priority;
        }
    }

    private async Task LoadComments()
    {
        _comments = await Http.GetFromJsonAsync<List<CommentDto>>($"comments/ticket/{Id}");
    }

    private async Task AddComment()
    {
        if (string.IsNullOrWhiteSpace(_newComment)) return;
        if (Session.CurrentUser == null) return;

        var createComment = new CreateCommentDto
        {
            Content = _newComment,
            TicketId = Id,
            UserId = Session.CurrentUser.Id
        };

        await Http.PostAsJsonAsync("comments", createComment);
        _newComment = string.Empty;
        await LoadComments();
    }

    private async Task UpdateTicket()
    {
        if (_ticket == null) return;

        var updateDto = new UpdateTicketDto
        {
            Title = _ticket.Title,
            Description = _ticket.Description,
            Status = _selectedStatus,
            Priority = _selectedPriority
        };

        var response = await Http.PutAsJsonAsync($"tickets/{Id}", updateDto);
        if (response.IsSuccessStatusCode)
        {
            await LoadTicket();
        }
    }

    private async Task DeleteTicket()
    {
        var response = await Http.DeleteAsync($"tickets/{Id}");
        if (response.IsSuccessStatusCode)
        {
            Nav.NavigateTo("/tickets");
        }
    }

    private async Task DeleteComment(int commentId)
    {
        var response = await Http.DeleteAsync($"comments/{commentId}");
        if (response.IsSuccessStatusCode)
        {
            await LoadComments();
        }
    }

    private string GetStatusBadge(TicketStatus status) => status switch
    {
        TicketStatus.Open => "bg-primary",
        TicketStatus.InProgress => "bg-warning",
        TicketStatus.Pending => "bg-info",
        TicketStatus.Resolved => "bg-success",
        TicketStatus.Closed => "bg-secondary",
        _ => "bg-secondary"
    };

    private string GetPriorityBadge(TicketPriority priority) => priority switch
    {
        TicketPriority.Low => "bg-success",
        TicketPriority.Medium => "bg-info",
        TicketPriority.High => "bg-warning",
        TicketPriority.Critical => "bg-danger",
        _ => "bg-secondary"
    };
}