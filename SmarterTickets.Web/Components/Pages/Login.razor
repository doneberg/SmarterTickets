@page "/login"
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Nav
@rendermode InteractiveServer
@using SmarterTickets.Core.DTOs
@using SmarterTickets.Core.Enums
@using SmarterTickets.Services

<PageTitle>Login</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header text-center">
                    <h3>🎫 SmarterTickets</h3>
                    <p class="text-muted mb-0">Sign in to continue</p>
                </div>
                <div class="card-body">

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">@_errorMessage</div>
                    }

                    @if (_isLoading)
                    {
                        <div class="alert alert-info">
                            ⏳ Server is waking up, please wait...
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" @bind="_email" disabled="@_isLoading" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" @bind="_password" disabled="@_isLoading" />
                    </div>
                    <button class="btn btn-primary w-100 mb-3" @onclick="HandleLogin" disabled="@_isLoading">
                        @if (_isLoading) { <span>Loading...</span> } else { <span>Login</span> }
                    </button>

                    <hr />
                    <p class="text-center text-muted">Demo Access</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary" @onclick="LoginAsUser" disabled="@_isLoading">
                            👤 Continue as Demo User
                        </button>
                        <button class="btn btn-outline-danger" @onclick="LoginAsAdmin" disabled="@_isLoading">
                            🔑 Continue as Demo Admin
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _errorMessage = string.Empty;
    private bool _isLoading = false;

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        try
        {
            var users = await Http.GetFromJsonAsync<List<UserDto>>("users");
            var user = users?.FirstOrDefault(u => u.Email == _email);

            if (user == null)
            {
                _errorMessage = "Invalid email or password.";
                return;
            }

            Session.Login(user);
            Nav.NavigateTo("/tickets");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Server is waking up, please try again in 30 seconds!";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoginAsUser()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        try
        {
            var users = await Http.GetFromJsonAsync<List<UserDto>>("users");
            var user = users?.FirstOrDefault(u => u.Role == UserRole.User);

            if (user == null)
            {
                _errorMessage = "No demo user found. Please seed the database first.";
                return;
            }

            Session.Login(user);
            Nav.NavigateTo("/tickets");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Server is waking up, please try again in 30 seconds!";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoginAsAdmin()
    {
        _isLoading = true;
        _errorMessage = string.Empty;
        try
        {
            var users = await Http.GetFromJsonAsync<List<UserDto>>("users");
            var user = users?.FirstOrDefault(u => u.Role == UserRole.Admin);

            if (user == null)
            {
                _errorMessage = "No demo admin found. Please seed the database first.";
                return;
            }

            Session.Login(user);
            Nav.NavigateTo("/tickets");
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Server is waking up, please try again in 30 seconds!";
        }
        finally
        {
            _isLoading = false;
        }
    }
}