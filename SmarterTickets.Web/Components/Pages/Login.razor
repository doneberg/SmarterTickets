@page "/login"
@inject HttpClient Http
@inject SessionService Session
@inject NavigationManager Nav
@rendermode InteractiveServer
@using SmarterTickets.Core.DTOs
@using SmarterTickets.Core.Enums
@using SmarterTickets.Services

<PageTitle>Login</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header text-center">
                    <h3>🎫 SmarterTickets</h3>
                    <p class="text-muted mb-0">Sign in to continue</p>
                </div>
                <div class="card-body">

                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger">@_errorMessage</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" @bind="_email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="form-control" @bind="_password" />
                    </div>
                    <button class="btn btn-primary w-100 mb-3" @onclick="HandleLogin">
                        Login
                    </button>

                    <hr />
                    <p class="text-center text-muted">Demo Access</p>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary" @onclick="LoginAsUser">
                            👤 Continue as Demo User
                        </button>
                        <button class="btn btn-outline-danger" @onclick="LoginAsAdmin">
                            🔑 Continue as Demo Admin
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _errorMessage = string.Empty;

    private async Task HandleLogin()
    {
        // real auth to be implemented later
        // For now just check if user exists by email
        var users = await Http.GetFromJsonAsync<List<UserDto>>("users");
        var user = users?.FirstOrDefault(u => u.Email == _email);

        if (user == null)
        {
            _errorMessage = "Invalid email or password.";
            return;
        }

        Session.Login(user);
        Nav.NavigateTo("/tickets");
    }

    private async Task LoginAsUser()
    {
        // Logs in as the first non-admin user in the database
        var users = await Http.GetFromJsonAsync<List<UserDto>>("users");
        var user = users?.FirstOrDefault(u => u.Role == UserRole.User);

        if (user == null)
        {
            _errorMessage = "No demo user found. Please seed the database first.";
            return;
        }

        Session.Login(user);
        Nav.NavigateTo("/tickets");
    }

    private async Task LoginAsAdmin()
    {
        // Logs in as the first admin user in the database
        var users = await Http.GetFromJsonAsync<List<UserDto>>("users");
        var user = users?.FirstOrDefault(u => u.Role == UserRole.Admin);

        if (user == null)
        {
            _errorMessage = "No demo admin found. Please seed the database first.";
            return;
        }

        Session.Login(user);
        Nav.NavigateTo("/tickets");
    }
}