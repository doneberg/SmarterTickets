@page "/profile"
@inject SessionService Session
@inject NavigationManager Nav
@rendermode InteractiveServer
@using SmarterTickets.Services
@using SmarterTickets.Core.Enums

<PageTitle>My Profile</PageTitle>

@if (!Session.IsLoggedIn)
{
    Nav.NavigateTo("/login");
    return;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header">
                    <h4 class="mb-0">My Profile</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center 
                             justify-content-center me-3" 
                             style="width:60px;height:60px;font-size:1.5rem;">
                            @Session.CurrentUser?.FirstName[0]@Session.CurrentUser?.LastName[0]
                        </div>
                        <div>
                            <h5 class="mb-0">
                                @Session.CurrentUser?.FirstName @Session.CurrentUser?.LastName
                            </h5>
                            <small class="text-muted">@Session.CurrentUser?.Email</small>
                        </div>
                    </div>

                    <hr />

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Role</div>
                        <div class="col-sm-8">
                            @if (Session.IsAdmin)
                            {
                                <span class="badge bg-danger">Administrator</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">User</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">Email</div>
                        <div class="col-sm-8">@Session.CurrentUser?.Email</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 fw-bold">User ID</div>
                        <div class="col-sm-8">#@Session.CurrentUser?.Id</div>
                    </div>

                    <hr />

                    <button class="btn btn-outline-danger" @onclick="Logout">
                        Logout
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void Logout()
    {
        Session.Logout();
        Nav.NavigateTo("/login");
    }
}